<UserControl x:Class="QPlayer.Views.AudioLimiterControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local='clr-namespace:QPlayer.Views'
             xmlns:vm='clr-namespace:QPlayer.ViewModels;assembly=QPlayer'
             xmlns:util='clr-namespace:QPlayer.Utilities;assembly=QPlayer'
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800" d:DataContext="{d:DesignInstance Type=vm:AudioLimiterViewModel}">
    <StackPanel>
        <DockPanel ToolTip="Enables the audio limiter which applies limiting to the audio signal just before it gets sent to the audio driver. This is useful in preventing accidental clipping/distortion when multiple sound cues are playing.">
            <Label Content="Enabled" />
            <CheckBox IsChecked='{Binding Enabled, UpdateSourceTrigger=Default}' Margin='8,2,2,2' DockPanel.Dock='Right' />
        </DockPanel>
        <Grid IsEnabled="{Binding Enabled, Mode=OneWay}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition/>
                <ColumnDefinition/>
                <ColumnDefinition/>
                <ColumnDefinition/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition/>
                <RowDefinition/>
                <RowDefinition/>
            </Grid.RowDefinitions>
            <local:Knob Grid.Column="0" MaxWidth="50" Value="{Binding InputGain}" Label="In Gain" ValueFormat="{}{0:F2} dB" MinValue="-32" MaxValue="32" Power="1"
                ToolTip="A gain adjustment applied before the limiter is applied."/>
            <local:Knob Grid.Column="1" MaxWidth="50" Value="{Binding Threshold}" Label="Thresh" ValueFormat="{}{0:F2} dB" MinValue="-50" MaxValue="0" Power="1"
                ToolTip="The threshold volume above which audio starts to get limited."/>
            <!--<local:Knob Grid.Column="2" MaxWidth="50" Value="{Binding Attack}" Label="Attack" ValueFormat="{}{0:F2} ms" MinValue="0.01" MaxValue="100" Power="3"
                ToolTip="The attack or rise time of the limiter, smaller values will be louder and punchier at the cost of more distortion at the extreme."/>-->
            <local:Knob Grid.Column="2" MaxWidth="50" Value="{Binding Release}" Label="Release" ValueFormat="{}{0:F1} ms" MinValue="1" MaxValue="2000" Power="3"
                ToolTip="The release or fall time of the limiter, smaller values will be louder and punchier at the cost of more distortion at the extreme."/>
            <local:Knob Grid.Column="3" MaxWidth="50" Value="{Binding CompGain}" Label="Compress" ValueFormat="{}{0:F2}" MinValue="0" MaxValue="20" Power="3"/>

            <Button Grid.Row="1" Grid.Column="0" Content="Auto Gain" VerticalAlignment="Top" Height="30" Command="{Binding AutoGainCommand}" Margin="2" ToolTip="Sets the input gain of the limiter to attenuate or boost the loudest individual sound cue in the cue stack such that it reaches 0dBfs."/>
            <!--<local:Knob Grid.Row="1" Grid.Column="3" MaxWidth="50" Value="{Binding CompRatio}" Label="CRatio" ValueFormat="{}{0:F3}" MinValue="0" MaxValue="1" Power="2"/>
            <local:Knob Grid.Row="2" Grid.Column="0" MaxWidth="50" Value="{Binding CompGain}" Label="CThresh" ValueFormat="{}{0:F2}" MinValue="0" MaxValue="20" Power="3"/>
            <CheckBox Grid.Row="2" Grid.Column="1" Grid.ColumnSpan="2" MaxWidth="100" Content="Write WAV" IsChecked="{Binding Write}"/>-->
        </Grid>
        <Grid Margin="0,5,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="24"/>
                <ColumnDefinition/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition/>
                <RowDefinition/>
            </Grid.RowDefinitions>
            <Grid.Resources>
                <Style TargetType="local:MeterBar" BasedOn="{StaticResource {x:Type ProgressBar}}">
                    <Setter Property="Foreground" Value="#fb21"/>
                            <!--<Setter Property="Foreground" Value="#f12f"/>-->
                </Style>
            </Grid.Resources>
            <TextBlock Text="GR" VerticalAlignment="Center" Margin="4,0,0,0"/>
            <local:MeterBar Minimum="0" Maximum="30" Value="{Binding GR}" Height="10" VerticalAlignment="Center" HorizontalAlignment="Stretch" Grid.Column="1" RenderTransformOrigin="0.5,0.5">
                <local:MeterBar.RenderTransform>
                    <TransformGroup>
                        <RotateTransform Angle="180"/>
                    </TransformGroup>
                </local:MeterBar.RenderTransform>
            </local:MeterBar>

            <!--<ProgressBar Minimum="-100" Maximum="10" Value="{Binding DBG_Meter}" Height="10" VerticalAlignment="Center" HorizontalAlignment="Stretch" Grid.Column="1" Grid.Row="1" RenderTransformOrigin="0.5,0.5">
            </ProgressBar>-->
        </Grid>
    </StackPanel>
</UserControl>
